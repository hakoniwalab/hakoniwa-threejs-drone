{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hakoniwa.dev/schemas/scene-config.schema.json",
  "title": "Hakoniwa Threejs Scene Config (compact)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "droneTypesPath",
    "drones"
  ],
  "properties": {
    "version": { "type": "string" },
    "format": { "type": "string", "const": "compact" },
    "environments": { "type": "array" },
    "main_camera": { "type": "object" },
    "droneTypesPath": { "type": "string", "minLength": 1 },
    "drones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "droneType": { "type": "string", "minLength": 1 },
          "pos": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "hpr": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          }
        }
      }
    }
  }
}
